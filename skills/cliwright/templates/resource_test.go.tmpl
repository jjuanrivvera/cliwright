// Template: internal/api/<resource>_test.go  (cliwright GOAL.md §8)
// Test only what is UNIQUE to the resource (field quirks, custom actions); generic CRUD
// is already covered once in the core. newTestClient spins up an httptest server.
package api

import (
	"context"
	"net/http"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestWidgets_List(t *testing.T) {
	c := newTestClient(t, func(w http.ResponseWriter, r *http.Request) {
		assert.Equal(t, http.MethodGet, r.Method)
		assert.Equal(t, "/widgets", r.URL.Path)
		w.Header().Set("Content-Type", "application/json")
		_, _ = w.Write([]byte(`[{"id":"1","name":"Widget A","status":"open"}]`))
	})
	got, err := c.Widgets().List(context.Background(), ListParams{})
	require.NoError(t, err)
	require.Len(t, got, 1)
	assert.Equal(t, ID("1"), got[0].ID)
}
